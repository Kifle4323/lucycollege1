generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum ExamType {
  QUIZ
  MIDTERM
  FINAL
}

enum QuestionType {
  MCQ
  FITB
  SHORT_ANSWER
}

enum ProfileStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum SemesterType {
  FALL
  SPRING
  SUMMER
}

enum SemesterStatus {
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  GRADING
  COMPLETED
}

enum GradeLetter {
  A_PLUS  // A+ >= 90
  A       // A >= 85
  A_MINUS // A- >= 80
  B_PLUS  // B+ >= 75
  B       // B >= 70
  B_MINUS // B- >= 65
  C_PLUS  // C+ >= 60
  C       // C >= 50
  C_MINUS // C- >= 45
  D       // D >= 40
  F       // F < 40
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  role            Role     @default(STUDENT)
  profileImage    String?  // Base64 encoded profile image
  isProfileComplete Boolean @default(false) // Student has completed profile
  isApproved      Boolean  @default(false) // Account approved by admin
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  classStudents   ClassStudent[]
  classTeachers   ClassTeacher[]
  courseClasses   CourseClass[]   @relation("CourseClassTeacher")
  attempts        Attempt[]
  materials       Material[]
  liveSessions    LiveSession[]
  manualGrades    ManualGrade[]
  attendance      Attendance[]
  faceVerifications FaceVerification[]
  studentProfile  StudentProfile?
  courseSections  CourseSection[]  @relation("CourseSectionTeacher")
  enrollments     StudentEnrollment[]
  earlyExamRequests EarlyExamRequest[]
}

model StudentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    ProfileStatus @default(DRAFT)
  adminReviewedBy String?
  reviewedAt DateTime?
  rejectionReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  // === Personal - Basic Information ===
  firstName           String?
  fatherName          String?
  grandFatherName     String?
  firstNameLocal      String?  // Amharic
  fatherNameLocal     String?  // Amharic
  grandFatherNameLocal String? // Amharic
  dateOfBirthGC       DateTime?
  gender              String?  // MALE, FEMALE, OTHER
  placeOfBirth        String?
  motherTongue        String?
  healthStatus        String?  // Normal, etc.
  maritalStatus       String?  // Single, Married, etc.
  nationalIdFan       String?

  // === Personal - Location and Address ===
  citizenship         String?
  country             String?
  city                String?
  subCity             String?
  kebele              String?
  woreda              String?
  houseNumber         String?
  phone               String?
  email               String?
  pobox               String?

  // === Personal - Others ===
  economicalStatus    String?  // Low, Medium, High
  areaType            String?  // Pastoral, Non Pastoral
  tinNumber           String?
  accountNumber       String?

  // === Educational - Campus Related ===
  stream              String?  // Natural Science, Social Science
  entryYear           Int?
  sponsorCategory     String?  // Govt, Private, etc.
  sponsoredBy         String?
  nationalExamYearEC  Int?
  examinationId       String?
  admissionDate       DateTime?
  checkedInDate        DateTime?
  nationalExamResultTotal Int?

  // === Educational - National Exam Results ===
  examEnglish         Int?
  examPhysics         Int?
  examCivics          Int?
  examNaturalMath     Int?
  examChemistry       Int?
  examBiology         Int?
  examAptitude        Int?

  // === Documents ===
  documents           StudentDocument[]
}

model StudentDocument {
  id              String   @id @default(cuid())
  studentProfileId String
  documentType    String   // Elementary Completion, High School Transcripts, etc.
  fileName        String?
  fileUrl         String?  // Base64 or file path
  status          String   @default("NOT_SUBMITTED") // SUBMITTED, NOT_SUBMITTED
  uploadedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model Class {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  year        Int?
  section     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students     ClassStudent[]
  teachers     ClassTeacher[]
  courses      CourseClass[]
  liveSessions LiveSession[]
}

model ClassStudent {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  createdAt DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id])
  student User  @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId])
}

model ClassTeacher {
  id        String   @id @default(cuid())
  classId   String
  teacherId String
  createdAt DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id])
  teacher User  @relation(fields: [teacherId], references: [id])

  @@unique([classId, teacherId])
}

model CourseClass {
  id        String   @id @default(cuid())
  courseId  String
  classId   String
  teacherId String?
  createdAt DateTime @default(now())

  course   Course @relation(fields: [courseId], references: [id])
  class    Class  @relation(fields: [classId], references: [id])
  teacher  User?  @relation("CourseClassTeacher", fields: [teacherId], references: [id])

  @@unique([courseId, classId])
}

model Course {
  id           String   @id @default(cuid())
  title        String
  code         String   @unique
  description  String?
  creditHours  Int      @default(3) // Credit hours for the course
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  courseClasses CourseClass[]
  courseSections CourseSection[]
  assessments   Assessment[]
  materials     Material[]
  liveSessions  LiveSession[]
  gradeConfig   CourseGradeConfig?
  attendance    Attendance[]
}

model Material {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String?   // For text-based materials
  fileUrl     String?   // For uploaded files (URL)
  fileType    String?   // e.g., "pdf", "doc", "link"
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
  author User   @relation(fields: [createdBy], references: [id])
}

model LiveSession {
  id          String   @id @default(cuid())
  courseId    String
  classId     String
  teacherId   String
  title       String
  description String?
  scheduledAt DateTime
  duration    Int      // in minutes
  status      String   @default("SCHEDULED") // SCHEDULED, LIVE, ENDED
  meetingUrl  String   // Jitsi meeting room URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id])
  class    Class  @relation(fields: [classId], references: [id])
  teacher  User   @relation(fields: [teacherId], references: [id])
}

model Assessment {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  examType  ExamType @default(QUIZ)
  timeLimit Int?
  maxScore  Int      @default(100) // Maximum score for this assessment
  isOpen   Boolean  @default(false) // Teacher must open for students to take
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course       Course        @relation(fields: [courseId], references: [id])
  questions    Question[]
  attempts     Attempt[]
  manualGrades ManualGrade[]
}

model Question {
  id           String       @id @default(cuid())
  assessmentId String
  type         QuestionType @default(MCQ)
  prompt       String
  // MCQ fields
  optionA      String?
  optionB      String?
  optionC      String?
  optionD      String?
  correct      String?      // For MCQ: A, B, C, or D
  // FITB field
  correctAnswer String?    // For fill-in-the-blank
  // Short answer field
  modelAnswer  String?      // For teacher reference during grading
  points       Int          @default(1)
  createdAt    DateTime     @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  answers    Answer[]
}

model Attempt {
  id             String        @id @default(cuid())
  assessmentId   String
  studentId      String
  status         AttemptStatus @default(IN_PROGRESS)
  score          Int?
  startedAt      DateTime      @default(now())
  submittedAt    DateTime?
  faceVerified   Boolean       @default(false) // Face matched during exam
  faceVerifiedAt DateTime?     // When admin approved face match

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    User       @relation(fields: [studentId], references: [id])
  answers    Answer[]
  faceVerification FaceVerification?

  @@unique([assessmentId, studentId, startedAt])
}

// Face verification record for admin review when face doesn't match
model FaceVerification {
  id              String   @id @default(cuid())
  attemptId       String   @unique
  studentId       String
  capturedImage   String   // Base64 encoded image captured during exam
  matchedImage    String?  // Reference to stored profile image
  matchResult     Boolean  // False = face didn't match, needs admin review
  adminReviewed   Boolean  @default(false)
  adminApproved   Boolean  @default(false) // Admin approved the face match
  adminId         String?  // Admin who reviewed
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id])
  student User   @relation(fields: [studentId], references: [id])
}

model Answer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId String
  selected   String?  // For MCQ: A, B, C, or D
  textAnswer String?  // For FITB and SHORT_ANSWER
  score      Int?     // For teacher-graded questions
  feedback   String?  // Teacher feedback
  createdAt  DateTime @default(now())

  attempt  Attempt  @relation(fields: [attemptId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
}

// Manual grades entered by teacher (for non-online assessments like participation, projects, etc.)
model ManualGrade {
  id           String   @id @default(cuid())
  assessmentId String
  studentId    String
  score        Int      // Score out of maxScore
  feedback     String?  // Teacher feedback
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    User       @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, studentId])
}

// Grade configuration for a course (weights for each component)
model CourseGradeConfig {
  id             String   @id @default(cuid())
  courseId       String   @unique
  quizWeight     Int      @default(25)    // % weight for quizzes
  midtermWeight  Int      @default(25)    // % weight for midterm
  finalWeight    Int      @default(40)    // % weight for final
  attendanceWeight Int    @default(10)    // % weight for attendance
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

// Attendance marks entered by teacher
model Attendance {
  id           String   @id @default(cuid())
  courseId     String
  studentId    String
  score        Int      // Score out of 100 for attendance
  feedback     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id])
  student  User   @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
}

// === Academic Management Models ===

// Academic Year (e.g., "2024-2025")
model AcademicYear {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "2024-2025"
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  semesters   Semester[]
}

// Semester within an academic year
model Semester {
  id              String        @id @default(cuid())
  academicYearId  String
  type            SemesterType  // FALL, SPRING, SUMMER
  name            String        // e.g., "Fall 2024"
  startDate       DateTime
  endDate         DateTime
  registrationStart DateTime?
  registrationEnd   DateTime?
  // Official exam dates set by admin
  midtermExamDate   DateTime?   // Official midterm exam date
  finalExamDate     DateTime?   // Official final exam date
  examPeriodStart   DateTime?
  examPeriodEnd     DateTime?
  gradingDeadline   DateTime?
  status          SemesterStatus @default(UPCOMING)
  isCurrent       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id])
  courseSections  CourseSection[]

  @@unique([academicYearId, type])
}

// Course offered in a specific semester (Course Section)
model CourseSection {
  id          String   @id @default(cuid())
  courseId    String
  semesterId  String
  teacherId   String
  sectionCode String   // e.g., "CS101-A" (course code + section)
  schedule    String?  // e.g., "Mon/Wed 9:00-10:30"
  room        String?  // e.g., "Room 101"
  maxCapacity Int?
  isPublished Boolean  @default(false) // Visible to students for registration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id])
  semester    Semester @relation(fields: [semesterId], references: [id])
  teacher     User     @relation("CourseSectionTeacher", fields: [teacherId], references: [id])
  enrollments StudentEnrollment[]
  examSchedules ExamSchedule[]

  @@unique([courseId, semesterId, sectionCode])
}

// Student enrollment in a course section
model StudentEnrollment {
  id              String   @id @default(cuid())
  courseSectionId String
  studentId       String
  enrolledAt      DateTime @default(now())
  status          String   @default("ENROLLED") // ENROLLED, DROPPED, WITHDRAWN

  courseSection   CourseSection @relation(fields: [courseSectionId], references: [id])
  student         User          @relation(fields: [studentId], references: [id])
  grade           StudentGrade?

  @@unique([courseSectionId, studentId])
}

// Student's grade for a course section
model StudentGrade {
  id              String     @id @default(cuid())
  enrollmentId    String     @unique
  quizScore       Int?       // Score out of 100
  midtermScore    Int?       // Score out of 100
  finalScore      Int?       // Score out of 100
  attendanceScore Int?       // Score out of 100
  totalScore      Int?       // Calculated total score out of 100
  gradeLetter     GradeLetter?
  gradePoint      Float?     // 4.0, 3.75, 3.5, etc.
  isSubmitted     Boolean    @default(false) // Teacher has submitted final grade
  isPublished     Boolean    @default(false) // Admin has published grades
  submittedAt     DateTime?
  publishedAt     DateTime?
  feedback        String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  enrollment      StudentEnrollment @relation(fields: [enrollmentId], references: [id])
}

// Exam Schedule for a course section (Midterm, Final)
// Teacher proposes early exam date; if all students agree, exam can be early
model ExamSchedule {
  id              String   @id @default(cuid())
  courseSectionId String
  examType        ExamType // MIDTERM, FINAL
  // Official date from semester (set by admin)
  officialDate    DateTime?
  // Teacher's proposed early date (if they want to move it earlier)
  proposedDate    DateTime?
  duration        Int      // Duration in minutes
  location        String?  // Exam room/location
  instructions    String?
  // Early exam proposal status
  earlyExamStatus String?  @default("NONE") // NONE, PROPOSED, ALL_AGREED, APPROVED, REJECTED
  proposalDeadline DateTime? // Deadline for students to respond to early exam proposal
  // Final confirmed date (either proposed or official)
  confirmedDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courseSection   CourseSection @relation(fields: [courseSectionId], references: [id])
  earlyRequests   EarlyExamRequest[]

  @@unique([courseSectionId, examType])
}

// Early Exam Request - Students agree/disagree to take exam early
model EarlyExamRequest {
  id             String   @id @default(cuid())
  examScheduleId String
  studentId      String
  agreed         Boolean  @default(false) // true = agreed to early, false = wants official date
  respondedAt    DateTime? // When student responded
  createdAt      DateTime @default(now())

  examSchedule   ExamSchedule @relation(fields: [examScheduleId], references: [id])
  student        User        @relation(fields: [studentId], references: [id])

  @@unique([examScheduleId, studentId])
}
